{
  "name": "belt",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "xmcp dev & next dev",
    "dev:https": "next dev --experimental-https",
    "build": "xmcp build && next build",
    "start": "next start",
    "lint": "next lint",
    "setup": "bun install",
    "setup:run": "bun run setup && bun run dev",
    "db:generate": "drizzle-kit generate --config=./src/db/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=./src/db/drizzle.config.ts",
    "db:push": "drizzle-kit push --config=./src/db/drizzle.config.ts",
    "db:drop": "drizzle-kit drop --config=./src/db/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=./src/db/drizzle.config.ts",
    "db:seed": "tsx ./src/db/seeder.ts",
    "auth:generate": "bunx @better-auth/cli generate --config=./src/lib/auth/index.ts",
    "manage": "tsx ./src/manage/main.ts"
  },
